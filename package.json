{
  "type": "module",
  "name": "chartkit",
  "version": "1.0.0",
  "description": "A pure JavaScript charting library with Donut/Pie and Bar charts featuring animations, RTL/LTR support, and full customization.",
  "main": "dist/chartkit.esm.js",
  "unpkg": "dist/chartkit.min.js",
  "module": "dist/chartkit.esm.js",
  "files": [
    "dist/",
    "src/",
    "styles/"
  ],
  "scripts": {
    "build": "rollup -c",
    "build:watch": "rollup -c -w",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "lint": "eslint src/ tests/",
    "format": "prettier --write 'src/**/*.js' 'tests/**/*.js' 'styles/**/*.css'",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^0.4.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.2.0",
    "rollup": "^4.14.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anomalyco/chartkit"
  },
    "jest": {
    "testEnvironment": "jsdom",
    "transform": {},
    "moduleNameMapper": {
      "\\.css$": "<rootDir>/tests/styleMock.js"
    },
    "collectCoverageFrom": [
      "src/**/*.js"
    ]
  }
}
